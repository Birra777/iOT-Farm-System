# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_SOIL_RAW=sensors.soil.raw
KAFKA_TOPIC_WEATHER_RAW=sensors.weather.raw
KAFKA_TOPIC_AGGREGATED=sensors.aggregated
KAFKA_TOPIC_ALERTS=alerts.anomaly
KAFKA_TOPIC_DLQ=sensors.dlq

# PostgreSQL (matches docker-compose.yml defaults)
POSTGRES_DSN=postgres://agristream:agristream@localhost:5433/agristream?sslmode=disable

# API server
API_PORT=8080

# Sensor simulator — how often each sensor publishes a reading (seconds)
SIMULATOR_PUBLISH_INTERVAL_SECONDS=5

# Email alerts (leave SMTP_HOST empty to disable)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your-app-password
ALERT_EMAIL_TO=you@example.com

# AI Farm Advisor — powered by Claude (leave empty to disable)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
